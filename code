import numpy as np
import cv2
from tensorflow.keras.preprocessing import image

def predict_single_image(img_path, model, target_size=(128, 128), class_names=None):
    """
    Loads an image, preprocesses it, and predicts using the trained model.

    Args:
        img_path (str): Path to the image file.
        model (keras.Model): Trained Keras model.
        target_size (tuple): Image size used during training.
        class_names (list or None): Optional list of class labels.

    Returns:
        dict: Prediction info (probability and predicted class).
    """
    # Load image and resize
    img = image.load_img(img_path, target_size=target_size)
    img_array = image.img_to_array(img)

    # Normalize to [0,1] range if your model was trained that way
    img_array = img_array / 255.0

    # Expand dimensions to make batch of size 1
    img_batch = np.expand_dims(img_array, axis=0)

    # Predict
    pred_prob = model.predict(img_batch)[0][0] if model.output_shape[-1] == 1 else model.predict(img_batch)[0]

    # Interpret result
    if model.output_shape[-1] == 1:
        pred_class = 1 if pred_prob > 0.5 else 0
    else:
        pred_class = np.argmax(pred_prob)

    # Display
    print(f"\n Prediction for {img_path}:")
    print(f"  → Predicted class: {class_names[pred_class] if class_names else pred_class}")
    print(f"  → Probability: {pred_prob:.4f}")

    # Show image
    import matplotlib.pyplot as plt
    plt.imshow(img_array)
    plt.title(f"Pred: {class_names[pred_class] if class_names else pred_class} ({pred_prob:.2f})")
    plt.axis('off')
    plt.show()

    return {"pred_class": pred_class, "pred_prob": float(pred_prob)}
