Memory-safe generator with train/validation split & augmentation
def data_generator(file_list, img_size=128, batch_size=32, augment=False, seed=42):
    np.random.seed(seed)
    if augment:
        augmenter = ImageDataGenerator(
            rotation_range=30,
            width_shift_range=0.15,
            height_shift_range=0.15,
            shear_range=0.15,
            zoom_range=0.25,
            horizontal_flip=True,
            vertical_flip=True,
            fill_mode='nearest'
        )
    else:
        augmenter = None

    while True:
        np.random.shuffle(file_list)
        for i in range(0, len(file_list), batch_size):
            batch_data = file_list[i:i+batch_size]
            batch_imgs, batch_labels = [], []

            for file_path, label in batch_data:
                img = cv2.imread(file_path)
                if img is not None:
                    img = cv2.resize(img, (img_size, img_size))
                    batch_imgs.append(img)
                    batch_labels.append(label)

            X_batch = np.array(batch_imgs, dtype=np.float32) / 255.0
            y_batch = np.array(batch_labels, dtype=np.int32)

            if augmenter is not None:
                X_batch = next(augmenter.flow(X_batch, batch_size=len(X_batch), shuffle=False,seed=seed))

            yield X_batch, y_batch
